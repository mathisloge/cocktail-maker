{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "common",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "generator": "Ninja",
            "installDir": "${sourceDir}/dist",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug-build",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release-build",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "homebrew-macos-opt",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
                "CMAKE_CXX_STDLIB_MODULES_JSON": "/opt/homebrew/opt/llvm/lib/c++/libc++.modules.json",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++ -nostdinc++ -I/opt/homebrew/opt/llvm/include/c++/v1",
                "CMAKE_EXE_LINKER_FLAGS": "-L/opt/homebrew/opt/llvm/lib -Wl,-rpath,/opt/homebrew/opt/llvm/lib",
                "CMAKE_SHARED_LINKER_FLAGS": "-L/opt/homebrew/opt/llvm/lib -Wl,-rpath,/opt/homebrew/opt/llvm/lib",
                "CMAKE_OSX_SYSROOT": "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
            }
        },
        {
            "name": "developer",
            "displayName": "Developer",
            "inherits": [
                "common",
                "debug-build",
                "homebrew-macos-opt"
            ],
            "cacheVariables": {
                "BUILD_TESTING": true,
                "SANITIZE_ADDRESS": true,
                "SANITIZE_UNDEFINED": true
            }
        },
        {
            "name": "production",
            "displayName": "Production build",
            "inherits": [
                "common",
                "release-build"
            ],
            "cacheVariables": {
                "BUILD_TESTING": false
            }
        }
    ],
    "buildPresets": [
        {
            "name": "developer",
            "configurePreset": "developer"
        },
        {
            "name": "production",
            "configurePreset": "production"
        }
    ],
    "testPresets": [
        {
            "name": "developer",
            "configurePreset": "developer",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "ignore",
                "stopOnFailure": true
            }
        }
    ],
    "packagePresets": [
        {
            "name": "production",
            "configurePreset": "production",
            "generators": [
                "DEB"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "production",
            "steps": [
                {
                    "type": "configure",
                    "name": "production"
                },
                {
                    "type": "build",
                    "name": "production"
                },
                {
                    "type": "package",
                    "name": "production"
                }
            ]
        }
    ]
}
