{
    "$schema": "../recipe-schema.json",
    "name": "Mojito",
    "tags": [
        "Klassisch",
        "Erfrischend",
        "Longdrink"
    ],
    "description": "Der Mojito ist ein erfrischender Cocktail aus Rum, Minze, Limette, Zucker und Soda – perfekt für den Sommer.",
    "nominal_serving_volume": 250,
    "steps": [
        {
            "kind": "parallel",
            "steps": [
                {
                    "kind": "dispense",
                    "ingredient": "white_rum",
                    "volume": 50
                },
                {
                    "kind": "dispense",
                    "ingredient": "soda",
                    "volume": 140
                },
                {
                    "kind": "dispense",
                    "ingredient": "lime_juice",
                    "volume": 30
                }
            ]
        },
        {
            "kind": "manual",
            "text": "2 Minzblätter"
        },
        {
            "kind": "manual",
            "text": "2 TL Zucker"
        }
    ]
}
