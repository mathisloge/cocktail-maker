{
    "$schema": "../recipe-schema.json",
    "name": "Mojito",
    "tags": [
        "classic"
    ],
    "description": "Der Mojito ist ein erfrischender Cocktail aus Rum, Minze, Limette, Zucker und Soda – perfekt für den Sommer.",
    "nominal_serving_volume": 250,
    "steps": [
        {
            "kind": "parallel",
            "steps": [
                {
                    "kind": "dispense",
                    "ingredient": "bacardi",
                    "volume": 89
                },
                {
                    "kind": "dispense",
                    "ingredient": "lime_juice",
                    "volume": 30
                },
                {
                    "kind": "dispense",
                    "ingredient": "soda",
                    "volume": 120
                }
            ]
        },
        {
            "kind": "manual",
            "text": "2 Minzblätter"
        },
        {
            "kind": "manual",
            "text": "2 TL Zucker"
        }
    ]
}
