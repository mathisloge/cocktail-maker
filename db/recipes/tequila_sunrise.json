{
    "$schema": "../recipe-schema.json",
    "name": "Tequila Sunrise",
    "tags": [
        "Klassisch",
        "Fruchtig",
        "Longdrink"
    ],
    "description": "Der Tequila Sunrise ist ein farbenfroher Cocktail aus Tequila, Orangensaft und Grenadine, der mit seinem sanften Farbverlauf und seinem fruchtig-süßen Geschmack Urlaubsstimmung verbreitet.",
    "nominal_serving_volume": 250,
    "steps": [
        {
            "kind": "parallel",
            "steps": [
                {
                    "kind": "dispense",
                    "ingredient": "white_tequila",
                    "volume": 40
                },
                {
                    "kind": "dispense",
                    "ingredient": "orange_juice",
                    "volume": 150
                }
            ]
        },
        {
            "kind": "dispense",
            "ingredient": "grenadine",
            "volume": 10
        },
        {
            "kind": "manual",
            "text": "2 Eiswürfel"
        }
    ]
}
