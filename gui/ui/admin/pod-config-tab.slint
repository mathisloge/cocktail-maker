import {
    TabWidget,
    ListView,
    HorizontalBox,
    ComboBox,
    VerticalBox,
    Button,
    ScrollView,
} from "std-widgets.slint";
import {
    SystemLog,
    SmallText,
    PulseDot,
    MediumText,
} from "../components.slint";
import {
    Pod,
    Dispenser,
    ConnectionState,
    DispenserType,
    Ingredient,
} from "../data.slint";
import { Palette } from "../palette.slint";

component PodListDelegate inherits Rectangle {
    in property <Pod> pod;
    in property <bool> selected;
    callback clicked();

    background: Palette.background-card;
    border-width: 1px;
    border-color: root.selected ? Palette.border-strong : Palette.border-subtle;
    animate background, border-color { duration: 100ms; }

    HorizontalBox {
        cross-axis-alignment: center;
        PulseDot {
            pulse: pod.connection-state == ConnectionState.connecting;
            background: pod.connection-state == ConnectionState.connected ? Palette.log-info :
                pod.connection-state == ConnectionState.connecting ? Palette.log-debug :
                Palette.log-error;
        }

        title := SmallText {
            text: pod.id;
            animate color { duration: 100ms; }
        }
    }

    touch-area := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    states [
        pressed when touch-area.pressed: {
            root.background: Palette.background-elevated.brighter(1);
            root.border-color: Palette.border;
            title.color: Palette.text-primary;
        }
        hover when touch-area.has-hover: {
            root.background: Palette.background-elevated;
        }
    ]
}

export component PodConfigTab inherits Rectangle {
    in property <[Pod]> pods: [
        {
            id: "Pod-Connected",
            connection_state: ConnectionState.connected,
            dispensers:[
                { id: 1, type: DispenserType.pump },
                { id: 2, type: DispenserType.pump },
                { id: 3, type: DispenserType.pump },
                { id: 4, type: DispenserType.pump },
                { id: 5, type: DispenserType.valve },
            ]
        },
        { id: "Pod-Connecting", connection_state: ConnectionState.connecting },
        { id: "Pod-Disconnected", connection_state: ConnectionState.disconnected },
    ];
    in property <[string]> ingredient-ids: ["vodka", "orange_juice", "test2"];
    private property <Pod> selected;

    callback identify-dispenser(Pod, Dispenser);
    callback assign-ingredient(Pod, Dispenser, string);

    sidebar := VerticalLayout {
        x: 0;
        y: 0;
        width: 33%;

        ListView {
            for pod in pods: PodListDelegate {
                width: parent.width;
                height: 50px;
                pod: pod;
                selected: root.selected == pod;
                clicked => { root.selected = pod; }
            }
        }
    }

    split := Rectangle {
        width: 1px;
        height: 100%;
        x: sidebar.width;
        y: 0;
        background: Palette.border;
    }

    content := VerticalBox {
        x: split.x + split.width;
        y: 0;
        width: root.width - sidebar.width - split.width;
        alignment: stretch;

        MediumText {
            text: selected.id;
        }

        ScrollView {
            VerticalBox {
                for dispenser in root.selected.dispensers: HorizontalBox {
                    cross-axis-alignment: center;
                    SmallText {
                        text: "Dispenser " + dispenser.id;
                    }

                    ComboBox {
                        height: 40px;
                        model: root.ingredient-ids;
                        selected(current-value) => {
                            assign-ingredient(selected, dispenser, current-value);
                        }
                    }

                    Button {
                        text: "Identify";
                        height: 40px;
                        clicked => { identify-dispenser(selected, dispenser); }
                    }

                    Button {
                        text: "Calibrate";
                        height: 40px;
                    }
                }
            }
        }
    }
}
