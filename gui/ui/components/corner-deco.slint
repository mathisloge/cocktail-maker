import { Palette } from "../palette.slint";
export component CornerDeco {
    private property <length> inset: 14px;
    private property <length> mark-length: 18px;
    private property <length> mark-thickness: 1px;
    private property <float> mark-opacity: 0.4;

    Rectangle {
        x: root.inset;
        y: root.inset;
        width: root.mark-length;
        height: root.mark-thickness;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: root.inset;
        y: root.inset;
        width: root.mark-thickness;
        height: root.mark-length;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: parent.width - root.inset - root.mark-length - root.mark-thickness;
        y: root.inset;
        width: root.mark-length;
        height: root.mark-thickness;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: parent.width - root.inset - root.mark-thickness;
        y: root.inset;
        width: root.mark-thickness;
        height: root.mark-length;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: root.inset;
        y: parent.height - root.inset - root.mark-thickness;
        width: root.mark-length;
        height: root.mark-thickness;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: root.inset;
        y: parent.height - root.inset - root.mark-length - root.mark-thickness;
        width: root.mark-thickness;
        height: root.mark-length;
        background: Palette.accent;
        opacity: root.mark-opacity;
    }

    Rectangle {
        x: parent.width - root.inset - root.mark-length - root.mark-thickness;
        y: parent.height - root.inset - root.mark-thickness;
        width: root.mark-length;
        height: root.mark-thickness;
        background: Palette.accent;
        opacity: root.mark-opacity;
