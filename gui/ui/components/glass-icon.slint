import { Palette } from "../palette.slint";
import { GlassIconData } from "../data.slint";

export component GlassIcon {
    in property <GlassIconData> data;
    in property <color> stroke-color: Palette.accent;
    in property <length> stroke-width: 2px;

    Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: root.data.viewbox-width;
        viewbox-height: root.data.viewbox-height;

        commands: root.data.outline;
        fill: transparent;
        stroke: root.stroke-color;
        stroke-width: root.stroke-width;
    }

    for rim-cmd in root.data.rim: Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: root.data.viewbox-width;
        viewbox-height: root.data.viewbox-height;

        commands: rim-cmd;
        fill: transparent;
        stroke: root.stroke-color;
        stroke-width: root.stroke-width * 0.6;
        opacity: 0.7;
    }
}

