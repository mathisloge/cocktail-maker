import { Palette, Layout } from "../palette.slint";

export component LargeText inherits Text {
    in property <bool> primary;
    color: primary ? Palette.text-primary : Palette.text-secondary;
    letter-spacing: 1.5pt;
    font-size: Layout.font-size-display;
    font-weight: FontWeight.bold;
    horizontal-alignment: center;
}
