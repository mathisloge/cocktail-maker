import { Palette } from "../palette.slint";
export component PulseDot inherits Rectangle {
    in property <bool> pulse: true;
    width: 7px;
    height: 7px;
    border-radius: self.height / 2;
    background: Palette.accent;
    opacity: 0.45;
    animate opacity {
        duration: 700ms;
        easing: ease-in-out;
    }

    animate background {
        duration: 700ms;
        easing: ease-in-out;
    }

    Timer {
        interval: 700ms;
        running: root.visible && root.pulse;
        triggered => {
            root.opacity = root.opacity > 0.7 ? 0.3 : 1.0;
        }
    }
}
