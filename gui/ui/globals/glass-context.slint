        {
            id: "highball",
            display-name: "Highball Glas",
            common-volumes-ml: [300, 350, 400, 450, 500],
            icon: {
                viewbox-width: 100,
                viewbox-height: 180,
                outline: "M 22 18 L 22 158 Q 22 162 26 162 L 74 162 Q 78 162 78 158 L 78 18",
                rim: ["M 18 18 L 82 18", "M 22 26 L 78 26"]
            }
        },
        {
            id: "wine",
            display-name: "Weinglas",
            common-volumes-ml: [300],
            icon: {
                viewbox-width: 100,
                viewbox-height: 180,
                outline: "M 15 30 Q 15 20 25 20 L 75 20 Q 85 20 85 30 Q 85 70 50 100 Q 15 70 15 30 M 50 100 L 50 150 M 25 158 Q 50 166 75 158",
                rim: ["M 15 30 L 85 30"]
            }
        }
    ];
}
