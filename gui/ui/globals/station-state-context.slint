import {
    LogEntry,
    Pod,
    RecipeView,
    Dispenser,
    ConnectionState,
    DispenserType,
    Page,
} from "./../data.slint";
export global StationStateContext {
    out property <string> station-name: "Sir Mix-A-Lot";
    in-out property <bool> station-ready: false; // backend should set this
    in-out property <Page> active-screen: Page.cocktail-list-page;
    in-out property <[LogEntry]> log-entries: [];
    in-out property <[Pod]> pods: /* example data */[
        {
            id: "Pod-Connected",
            connection_state: ConnectionState.connected,
            dispensers:[
                { id: 1, type: DispenserType.pump },
                { id: 2, type: DispenserType.pump },
                { id: 3, type: DispenserType.pump },
                { id: 4, type: DispenserType.pump },
                { id: 5, type: DispenserType.valve },
            ]
        },
        { id: "Pod-Connecting", connection_state: ConnectionState.connecting },
        { id: "Pod-Disconnected", connection_state: ConnectionState.disconnected },
    ];
    // Maintenance access
    // Set by C++ after a successful/failed submit-operator-pin call.
    // Not authoritative - backend navigates.
    in property <bool> operator-authenticated: false;
    in property <int> operator-remaining-attempts: 5;
    in property <bool> operator-locked-out: false;
    in property <int> operator-lockout-seconds-remaining: 0;
    callback submit-operator-pin(string);

    callback highlight-dispenser(Pod, Dispenser);

    // navigation
    callback navigated-to(Page, Page);
    callback navigate-to(screen: Page);
}
