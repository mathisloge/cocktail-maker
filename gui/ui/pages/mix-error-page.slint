
import { Palette, Layout } from "../palette.slint";
import { ProcessContext } from "../globals/process-context.slint";
import {
    SeparatorText,
    CommandItem,
    SmallText,
    MediumText,
    LargeText,
    CornerDeco,
} from "../components.slint";
import { Button } from "../components/button.slint";
import { Page } from "page.slint";
import { RecipeContext } from "../globals/recipe-context.slint";

// ─────────────────────────────────────────────────────────────────────
//  Small local helper — one "what failed" detail row
//  (not exported; scoped to this file)
// ─────────────────────────────────────────────────────────────────────
component ErrorDetailRow inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <string> sub-label;

    height: 56px;
    background: Palette.background-card;
    border-width: 1px;
    border-color: Palette.border;

    HorizontalLayout {
        padding: 0px;
        spacing: Layout.spacing-md;

        Rectangle {
            width: 30px;
            horizontal-stretch: 0;
            SmallText {
                text: root.icon;
                font-size: Layout.font-size-md;
                letter-spacing: 0px;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: Layout.spacing-xs;
            MediumText {
                text: root.label;
                font-italic: false;
                font-weight: FontWeight.semi-bold;
                font-size: Layout.font-size-sm;
                color: Palette.text-primary;
            }

            SmallText {
                text: root.sub-label;
                font-size: Layout.font-size-xs;
                letter-spacing: 1.5px;
                color: Palette.text-muted;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        Rectangle {
            horizontal-stretch: 0;
            background: transparent;
            border-width: 1px;
            border-color: Palette.text-error;
            HorizontalLayout {
                padding: Layout.spacing-xs;
                SmallText {
                    text: "FAILED";
                    font-size: Layout.font-size-xs;
                    letter-spacing: 2px;
                    font-weight: FontWeight.semi-bold;
                    color: Palette.text-error;
                    vertical-alignment: center;
                }
            }
        }
    }
}

export component MixErrorPage inherits Page {
    private property <string> cocktail-name:            RecipeContext.active-recipe.name;
    private property <string> error-title:              ProcessContext.error-title;
    private property <string> error-reason:             ProcessContext.error-description;
    private property <string> failed-ingredient-icon:   ProcessContext.error-item-category;
    private property <string> failed-ingredient-name:   ProcessContext.error-item-name;
    private property <string> failed-pod-label:         ProcessContext.error-item-details;
    callback cancel();

    // ── Continuous slow breathing pulse on the broken ring ───────
    property <bool> pulse: false;
    Timer {
        interval: 1700ms;
        running: true;
        triggered => { root.pulse = !root.pulse; }
    }

    HorizontalLayout {

        // ════════════════════════════════════════════════════
        //  LEFT  —  status icon
        // ════════════════════════════════════════════════════
        Rectangle {
            width: 380px;
            horizontal-stretch: 0;
            background: Palette.background;

            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: Palette.border;
            }

            CornerDeco {
                width: parent.width;
                height: parent.height;
            }

            VerticalLayout {
                alignment: center;
                spacing: 0;

                // ── Broken-ring icon ─────────────────────────
                HorizontalLayout {
                    alignment: center;
                    icon-stack := Rectangle {
                        width: 168px;
                        height: 168px;
                        background: transparent;

                        // Static amber base ring (the "glass rim")
                        Rectangle {
                            width: 112px;
                            height: 112px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            border-radius: self.height / 2;
                            border-width: root.pulse ? 1px : 3px;
                            border-color: root.pulse ? Palette.border : Palette.text-error;
                            background: Palette.background-elevated;
                            animate border-color, border-width {
                                duration: 400ms;
                                easing: ease-in-out;
                            }
                        }

                        Path {
                            width: 112px;
                            height: 112px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            viewbox-width: 100;
                            viewbox-height: 100;
                            // triangle, gently rounded corners
                            commands: "M 50 32 Q 52 32 53 34 L 64 58 Q 66 62 62 62 L 38 62 Q 34 62 36 58 L 47 34 Q 48 32 50 32 Z";
                            fill: transparent;
                            stroke: root.pulse ? Palette.border : Palette.text-error;
                            stroke-width: 2px;
                            opacity: root.mounted ? 1 : 0;
                            animate opacity, stroke {
                                duration: 400ms;
                                easing: ease-in-out;
                            }
                        }

                        Path {
                            width: 112px;
                            height: 112px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            viewbox-width: 100;
                            viewbox-height: 100;
                            // exclamation bar + dot
                            commands: "M 49 41 L 51 41 L 50.5 51 L 49.5 51 Z M 48.5 55 L 51.5 55 L 51.5 58 L 48.5 58 Z";
                            fill: root.pulse ? Palette.border : Palette.text-error;
                            stroke: transparent;
                            opacity: root.mounted ? 1 : 0;
                            animate opacity, fill {
                                duration: 400ms;
                                easing: ease-in-out;
                            }
                        }
                    }
                }

                Rectangle {
                    height: Layout.spacing-lg;
                    background: transparent;
                }

                VerticalLayout {
                    spacing: Layout.spacing-sm;
                    opacity: root.mounted ? 1 : 0;
                    animate opacity {
                        duration: 400ms;
                        delay: 280ms;
                    }

                    SmallText {
                        text: "ZUBEREITUNG UNTERBROCHEN";
                        color: Palette.text-error;
                        horizontal-alignment: center;
                    }

                    MediumText {
                        text: root.cocktail-name;
                        primary: false;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // ════════════════════════════════════════════════════
        //  RIGHT  —  details & actions
        // ════════════════════════════════════════════════════
        Rectangle {
            horizontal-stretch: 1;
            background: Palette.background;

            VerticalLayout {
                padding: Layout.spacing-xl * 1.4;
                spacing: 0;
                alignment: center;

                LargeText {
                    text: root.error-title;
                    opacity: root.mounted ? 1 : 0;
                    animate opacity {
                        duration: 400ms;
                        delay: 320ms;
                    }
                }

                Rectangle {
                    height: Layout.spacing-sm;
                    background: transparent;
                }

                MediumText {
                    text: root.error-reason;
                    wrap: word-wrap;
                    primary: true;

                    opacity: root.mounted ? 1 : 0;
                    animate opacity {
                        duration: 400ms;
                        delay: 360ms;
                    }
                }

                Rectangle {
                    height: Layout.spacing-lg;
                    background: transparent;
                }

                // ── Failed-at-step detail ─────────────────────
                if root.failed-ingredient-name != "": VerticalLayout {
                    spacing: Layout.spacing-sm;
                    opacity: root.mounted ? 1 : 0;
                    animate opacity {
                        duration: 400ms;
                        delay: 420ms;
                    }

                    SmallText {
                        text: "UNTERBROCHEN BEI";
                    }

                    ErrorDetailRow {
                        icon: root.failed-ingredient-icon;
                        label: root.failed-ingredient-name;
                        sub-label: root.failed-pod-label;
                    }
                }

                Rectangle {
                    height: Layout.spacing-xl;
                    background: transparent;
                }

                // ── Actions ────────────────────────────────────
                Button {
                    text: "ABBRECHEN";
                    opacity: root.mounted ? 1 : 0;
                    animate opacity {
                        duration: 400ms;
                        delay: 520ms;
                    }
                    clicked => { root.cancel(); }
                }
            }
        }
    }
}
