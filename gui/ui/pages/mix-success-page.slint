import {
    SmallText,
    MediumText,
    CornerDeco,
    LargeText,
    Button,
    BoostText,
} from "../components.slint";
import { Palette, Layout } from "../palette.slint";
import { Page } from "page.slint";
import { RecipeContext } from "../globals/recipe-context.slint";
import { ProcessContext } from "../globals/process-context.slint";

component StatChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value-color: Palette.text-primary;

    background: Palette.background-card;
    border-width: 1px;
    border-color: Palette.border;

    VerticalLayout {
        padding-top: Layout.spacing-sm;
        padding-bottom: Layout.spacing-sm;
        padding-left: Layout.spacing-md;
        padding-right: Layout.spacing-md;
        spacing: Layout.spacing-xs;
        alignment: center;

        SmallText {
            text: root.label;
            font-size: Layout.font-size-xs;
            letter-spacing: 2.5px;
            color: Palette.text-muted;
            horizontal-alignment: center;
        }

        MediumText {
            text: root.value;
            font-italic: false;
            font-weight: FontWeight.semi-bold;
            font-size: Layout.font-size-sm;
            color: root.value-color;
            horizontal-alignment: center;
        }
    }
}


export component MixSuccessPage inherits Page {
    private property <string> cocktail-name: RecipeContext.active-recipe.name;
    private property <duration> prep-time-seconds: ProcessContext.elapsed-time;
    private property <int> boost-value: ProcessContext.boost;
    callback finish();

    Timer {
        interval: 5s;
        running: true;
        triggered => { finish(); }
    }

    VerticalLayout {
        padding-top: Layout.spacing-xl * 1.4;
        padding-bottom: Layout.spacing-xl * 1.4;
        padding-left: Layout.spacing-xl * 1.2;
        padding-right: Layout.spacing-xl * 1.2;
        spacing: 0;
        alignment: center;

        LargeText {
            text: root.cocktail-name;
            font-size: Layout.font-size-xl;
            font-italic: true;
            opacity: root.mounted ? 1 : 0;
            animate opacity {
                duration: Palette.mount-animation-duration;
                easing: Palette.mount-animation-easing;
                delay: 320ms;
            }
        }

        Rectangle {
            height: Layout.spacing-sm;
            background: transparent;
        }

        BoostText {
            boost: root.boost-value;
            horizontal-alignment: center;
            opacity: root.mounted ? 1 : 0;
            primary: true;
            animate opacity {
                duration: Palette.mount-animation-duration;
                easing: Palette.mount-animation-easing;
                delay: 360ms;
            }
        }

        Rectangle {
            height: Layout.spacing-lg;
            background: transparent;
        }

        VerticalLayout {
            spacing: Layout.spacing-sm;
            opacity: root.mounted ? 1 : 0;
            animate opacity {
                duration: Palette.mount-animation-duration;
                easing: Palette.mount-animation-easing;
                delay: 420ms;
            }

            SmallText {
                text: "ZUSAMMENFASSUNG";
                font-size: Layout.font-size-xs;
                letter-spacing: 3.5px;
            }

            HorizontalLayout {
                spacing: Layout.spacing-sm;

                StatChip {
                    label: "BOOST";
                    value: root.boost-value == 0
                        ? "Normal"
                        : (root.boost-value > 0 ? "+" : "") + Math.round(root.boost-value) + "%";
                    value-color: root.boost-value > 0 ? Palette.boost-positive-text
                        : root.boost-value < 0 ? Palette.boost-negative-text
                        : Palette.accent-light;
                }

                StatChip {
                    label: "ZEIT";
                    value: root.prep-time-seconds / 1s + "s";
                    value-color: Palette.text-success;
                }
            }
        }

        Rectangle {
            height: Layout.spacing-md;
            background: transparent;
        }

        VerticalLayout {
            spacing: Layout.spacing-sm;
            opacity: root.mounted ? 1 : 0;
            animate opacity {
                duration: Palette.mount-animation-duration;
                easing: Palette.mount-animation-easing;
                delay: 460ms;
            }

            Rectangle {
                height: 2px;
                background: Palette.border;
                border-radius: 1px;
                Rectangle {
                    height: 2px;
                    border-radius: 1px;
                    width: root.mounted ? parent.width : 0px;
                    background: Palette.text-success;
                    animate width {
                        duration: 700ms;
                        easing: ease-out;
                        delay: 200ms;
                    }
                }
            }

            SmallText {
                text: "ALLES ERFOLGREICH GEMIXT";
                font-size: Layout.font-size-xs;
                letter-spacing: 2px;
                color: Palette.text-muted;
            }
        }

        Rectangle {
            height: Layout.spacing-xl;
            background: transparent;
        }

        Button {
            opacity: root.mounted ? 1 : 0;
            animate opacity {
                duration: Palette.mount-animation-duration;
                easing: Palette.mount-animation-easing;
                delay: 560ms;
            }
            secondary: true;
            text: "FERTIG →";
            clicked => { root.finish(); }
        }
    }
}
