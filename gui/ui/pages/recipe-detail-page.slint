import { ScrollView, HorizontalBox, Slider } from "std-widgets.slint";
import { RecipeView } from "../data.slint";
import { Palette } from "../palette.slint";
import {
    CommandListItem,
    Button,
    SeparatorText,
    LargeText,
    SmallText,
} from "../components.slint";
import { MediumText } from "../components/medium-text.slint";

export component RecipeDetailPage inherits Rectangle {
    in property <RecipeView> recipe;
    callback create-recipe(int);
    callback boost-recipe(int);

    background: Palette.background-elevated;

    sidebar := VerticalLayout {
        x: 0;
        y: 0;
        width: 33%;
        padding: 20px;
        padding-bottom: 60px;
        spacing: 60px;
        cross-axis-alignment: center;
        alignment: end;
        Image {
            source: recipe.image;
        }

        Rectangle {
            width: 90%;
            background: Palette.border;
            height: 1px;
        }

        VerticalLayout {
            spacing: 10px;
            cross-axis-alignment: center;
            alignment: center;
            LargeText {
                text: recipe.name;
                primary: true;
            }

            SmallText {
                text: recipe.tag-line[0];
                highlight: true;
            }
        }
    }

    split := Rectangle {
        width: 1px;
        height: 100%;
        x: sidebar.width;
        y: 0;
        background: Palette.border;
    }

    content := VerticalLayout {
        x: split.x + split.width;
        y: 0;
        width: root.width - sidebar.width - split.width;
        padding: 20px;
        padding-top: 40px;
        padding-bottom: 60px;
        spacing: 15px;
        alignment: LayoutAlignment.space-between;

        VerticalLayout {
            spacing: content.spacing;
            MediumText {
                text: recipe.description;
                color: Palette.text-muted;
            }

            Rectangle { }

            SeparatorText {
                text: "INGREDIENTS:";
            }

            GridLayout {
                spacing: 10px;
                for command[index] in recipe.commands: CommandListItem {
                    row: index / 2;
                    col: Math.mod(index, 2);
                    command: command;
                }
            }

            SeparatorText {
                text: "ALCOHOL BOOST:";
            }

            MediumText {
                text: "💪 Strength Adjustment";
                primary: true;
            }

            HorizontalBox {
                cross-axis-alignment: center;
                SmallText {
                    text: "mild";
                    color: Palette.boost-negative-text;
                }

                booster := Slider {
                    minimum: -50;
                    maximum: 50;
                    value: 0;

                    changed(value) => {
                        boost-recipe(value);
                    }
                }

                SmallText {
                    text: "strong";
                    color: Palette.boost-positive-text;
                }
            }
        }

        Button {
            text: "Prepare Cocktail →";
            clicked => {
                root.create-recipe(booster.value);
            }
        }
    }
}
