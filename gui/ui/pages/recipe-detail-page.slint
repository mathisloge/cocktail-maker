import { ScrollView, HorizontalBox, Slider } from "std-widgets.slint";
import { RecipeView } from "../data.slint";
import { Palette } from "../palette.slint";
import { CommandListItem, Button, SeperatorText } from "../components.slint";

export component RecipeDetailPage inherits Rectangle {
    in-out property <RecipeView> recipe;
    callback create-recipe(int);

    background: Palette.background-elevated;
    GridLayout {
        VerticalLayout {
            width: 33%;
            padding: 20px;
            padding-bottom: 60px;
            rowspan: 1;
            spacing: 60px;
            align-items: center;
            alignment: end;
            Image {
                source: recipe.image;
            }

            Rectangle {
                width: 90%;
                background: Palette.border;
                height: 1px;
            }

            VerticalLayout {
                spacing: 10px;
                align-items: center;
                alignment: center;
                Text {
                    text: recipe.name;
                    color: Palette.text-primary;
                    font-size: 40pt;
                    font-weight: FontWeight.bold;
                }

                Text {
                    text: recipe.tag-line[0];
                    color: Palette.text-secondary;
                }
            }
        }

        Rectangle {
            width: 1px;
            height: 100%;
            background: Palette.border;
        }

        content := VerticalLayout {
            padding: 20px;
            padding-top: 40px;
            padding-bottom: 60px;
            spacing: 15px;
            alignment: LayoutAlignment.space-between;
            rowspan: 2;

            VerticalLayout {
                spacing: content.spacing;
                Text {
                    text: recipe.description;
                    color: Palette.text-muted;
                    font-size: 12pt;
                }

                Rectangle { }

                SeperatorText {
                    text: "INGREDIENTS:";
                }

                GridLayout {
                    spacing: 10px;
                    for command in recipe.commands: CommandListItem {
                        command: command;
                    }
                }

                SeperatorText {
                    text: "ALCOHOL BOOST:";
                }

                Text {
                    text: "💪 Strength Adjustment";
                    color: Palette.text-primary;
                    font-size: 20pt;
                }

                HorizontalBox {
                    align-items: LayoutAlignItems.center;
                    Text {
                        text: "mild";
                        color: Palette.boost-negative-text;
                    }

                    booster:= Slider {
                        minimum: 0;
                        maximum: 100;
                        value: 50;
                    }

                    Text {
                        text: "strong";
                        color: Palette.boost-positive-text;
                    }
                }
            }

            Button {
                text: "Prepare Cocktail →";
                clicked => {
                    root.create-recipe(booster.value);
                }
            }
        }
    }
}
