import { ScrollView } from "std-widgets.slint";
import { RecipeCard } from "../components.slint";
import { RecipeContext } from "../globals/recipe-context.slint";
export component RecipeListPage inherits Rectangle {
    callback recipe-selected();

    ScrollView {
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        GridLayout {
            padding: 10px;
            spacing: 5px;
            for recipe[index] in RecipeContext.recipes: RecipeCard {
                row: index / 3;
                col: Math.mod(index, 3);
                recipe: recipe;
                clicked => {
                    RecipeContext.active-recipe = recipe;
                    root.recipe-selected()
                }
            }
        }
    }
}
