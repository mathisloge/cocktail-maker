import { ScrollView } from "std-widgets.slint";
import { RecipeCard } from "../components.slint";
import { RecipeContext } from "../globals/recipe-context.slint";
import { Page } from "page.slint";
import { Palette, Layout } from "../palette.slint";

export component RecipeListPage inherits Page {
    callback recipe-selected();

    ScrollView {
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;

        GridLayout {
            padding: Layout.spacing-sm;
            spacing: Layout.spacing-xs;
            for recipe[index] in RecipeContext.recipes: RecipeCard {
                row: index / 3;
                col: Math.mod(index, 3);
                width: (root.width - 2 * parent.padding - 2 * parent.spacing) / 3;
                height: self.width;
                recipe: recipe;
                opacity: root.mounted ? 1 : 0;
                animate opacity {
                    delay: index * 50ms;
                    duration: Palette.mount-animation-duration;
                    easing: Palette.mount-animation-easing;
                }
                clicked => {
                    RecipeContext.active-recipe = recipe;
                    root.recipe-selected()
                }
            }
        }
    }
}
