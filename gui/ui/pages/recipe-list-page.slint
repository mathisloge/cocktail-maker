import { ScrollView } from "std-widgets.slint";
import { RecipeView } from "../data.slint";
import { RecipeCard } from "../components.slint";
export component RecipeListPage inherits Rectangle {
    callback recipe-selected(RecipeView);

    in property <[RecipeView]> recipes;

    ScrollView {
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        GridLayout {
            padding: 10px;
            spacing: 5px;
            for recipe in recipes: RecipeCard {
                recipe: recipe;
                clicked => {
                    root.recipe-selected(recipe)
                }
            }
        }
    }
}
