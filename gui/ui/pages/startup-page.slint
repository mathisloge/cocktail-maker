import { Palette } from "../palette.slint";
import { LargeText, SmallText, Seperator, Button } from "../components.slint";
import { ProgressIndicator, Spinner, ScrollView } from "std-widgets.slint";

import { Spinner } from "std-widgets.slint";
import { CornerDeco } from "../components/corner-deco.slint";

export enum LogLevel { info, ok, wait, err }
export struct LogEntry {
    time_stamp: string,
    level: LogLevel,
    message: string,
}

// ─────────────────────────────────────────────────────────────────────
//  LOG ROW
// ─────────────────────────────────────────────────────────────────────
component LogRow inherits Rectangle {
    in property <LogEntry> entry;

    height: 26px;
    background: transparent;

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border-subtle;
    }

    HorizontalLayout {
        alignment: LayoutAlignment.start;
        padding-left: 20px;
        padding-right: 20px;
        spacing: 0;
        SmallText {
            text: root.entry.time-stamp;
            font-size: 5.5pt;
            letter-spacing: 0.8px;
            vertical-alignment: center;
            overflow: elide;
        }

        SmallText {
            text: "│";
            font-size: 6pt;
            letter-spacing: 0px;
            color: Palette.border;
            vertical-alignment: center;
            horizontal-stretch: 0;
        }

        SmallText {
            width: 44px;
            horizontal-stretch: 0;
            text: root.entry.level == LogLevel.ok ? "OK"
                : root.entry.level == LogLevel.err ? "ERROR"
                : root.entry.level == LogLevel.wait ? "WAIT"
                : "INFO";
            font-size: 5.5pt;
            letter-spacing: 1.5px;
            vertical-alignment: center;
            color: root.entry.level == LogLevel.ok ? Palette.text-success
                : root.entry.level == LogLevel.err ? Palette.text-error
                : root.entry.level == LogLevel.wait ? Palette.accent
                : Palette.text-muted;
        }

        SmallText {
            text: "│";
            font-size: 6pt;
            letter-spacing: 0px;
            color: Palette.border;
            vertical-alignment: center;
            horizontal-stretch: 0;
        }

        Rectangle {
            width: 12px;
            horizontal-stretch: 0;
            background: transparent;
        }

        SmallText {
            text: root.entry.message;
            font-size: 5.5pt;
            letter-spacing: 0.8px;
            vertical-alignment: center;
            overflow: elide;
            color: root.entry.level == LogLevel.err ? Palette.boost-positive-text
                : Palette.text-primary;
        }
    }
}


// ─────────────────────────────────────────────────────────────────────
//  BOOT SCREEN
// ─────────────────────────────────────────────────────────────────────
export component BootScreen inherits Rectangle {
    in property <string> machine-name: "Sir Mix-A-Lot";
    in property <bool> is-loading:   true;
    in-out property <[LogEntry]> log-entries:  [
        { time_stamp: "19:45.23", level:  LogLevel.ok, message: "Device xyz wird gesucht." },
        { time_stamp: "19:45.23", level:  LogLevel.err, message: "Device xyz wird gesucht." },
        { time_stamp: "19:45.23", level:  LogLevel.wait, message: "Device xyz wird gesucht." },
        { time_stamp: "19:45.23", level:  LogLevel.info, message: "Device xyz wird gesucht." },
    ];

    callback boot-complete();

    background: Palette.background;

    property <float> dot-opacity: 0.7;

    Timer {
        interval: 700ms;
        running: root.is-loading;
        triggered => {
            root.dot-opacity = root.dot-opacity > 0.6 ? 0.2 : 0.9;
        }
    }

    property <int> entry-count: log-entries.length;
    changed entry-count => {
        if log-scroll.viewport-height > log-scroll.height {
            log-scroll.viewport-y = log-scroll.height - log-scroll.viewport-height;
        }
    }

    HorizontalLayout {

        // ── LEFT: branding + spinner ─────────────────────────
        left-panel := Rectangle {
            horizontal-stretch: 42;
            background: Palette.background;

            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: Palette.border;
            }

            // Corner deco marks
            CornerDeco {
                width: 100%;
                height: 100%;
            }

            VerticalLayout {
                alignment: center;
                cross-axis-alignment: center;
                padding: 52px;
                spacing: 0;

                SmallText {
                    text: "COCKTAIL MACHINE";
                    font-size: 5.5pt;
                    letter-spacing: 4px;
                }

                Rectangle {
                    height: 18px;
                }

                LargeText {
                    text: root.machine-name;
                    font-italic: true;
                }

                Rectangle {
                    height: 10px;
                }

                Seperator {
                    width: 52px;
                }

                Rectangle {
                    height: 52px;
                }

                if root.is-loading:  Spinner {
                    indeterminate: true;
                    width: 52px;
                    height: 52px;
                }

                if !root.is-loading:  Button {
                    height: 52px;
                    text: "START →";
                }

                Rectangle {
                    height: 18px;
                    background: transparent;
                }

                SmallText {
                    text: root.is-loading ? "WIRD GESTARTET …" : "BEREIT";
                    color: root.is-loading ? Palette.accent : #5cad75;
                    animate color { duration: 400ms; }
                }
            }
        }

        // ── RIGHT: boot log ──────────────────────────────────
        Rectangle {
            horizontal-stretch: 58;
            background: Palette.background-card;

            VerticalLayout {
                spacing: 0;

                // Toolbar
                Rectangle {
                    height: 40px;
                    background: Palette.background;

                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: Palette.border;
                    }

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        spacing: 10px;
                        alignment: start;
                        cross-axis-alignment: center;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: root.is-loading ? Palette.accent : #5cad75;
                            opacity: root.dot-opacity;
                            animate background { duration: 300ms; }
                            animate opacity { duration: 300ms; }
                        }

                        SmallText {
                            text: "SYSTEM LOG";
                            font-size: 5.5pt;
                            letter-spacing: 3.5px;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            background: transparent;
                        }

                        SmallText {
                            text: root.log-entries.length + " LINES";
                            font-size: 5pt;
                            letter-spacing: 2px;
                            highlight: true;
                            vertical-alignment: center;
                        }
                    }
                }

                // Scrollable log
                log-scroll := Flickable {
                    viewport-height: log-content.preferred-height;

                    log-content := VerticalLayout {
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 0;
                        alignment: start;

                        for entry in root.log-entries: LogRow {
                            entry: entry;
                        }
                    }
                }
            }
        }
    }
}
