import { Palette, Layout } from "../palette.slint";
import {
    Button,
    SmallText,
    LargeText,
    CornerDeco,
    PulseDot,
} from "../components.slint";
import { Command, CommandStatus } from "../data.slint";
export component ManualCommandPopup inherits PopupWindow {
    close-policy: PopupClosePolicy.no-auto-close;
    in property <string> title: "Bitte führe den angezeigten Schritt aus:";
    in property <Command> command: { status: CommandStatus.in-progress, text:"2 Minzblätter", value:"" };
    callback confirmed();

    Rectangle {
        width: 100%;
        height: 100%;
        background: Palette.overlay-scrim;
    }

    Rectangle {
        height: 50%;
        width: 50%;
        x: root.width / 4;
        y: root.height / 4;
        background: Palette.background-elevated;
        border-width: 1px;
        border-color: Palette.border-strong;

        drop-shadow-color: Palette.shadow;
        drop-shadow-blur: 24px;

        CornerDeco {
            width: 100%;
            height: 100%;
        }

        box-layout := VerticalLayout {
            padding-top: Layout.spacing-xl;
            padding-left: Layout.spacing-xl * 1.2;
            padding-bottom: Layout.spacing-xl;
            padding-right: Layout.spacing-xl * 1.2;
            spacing: 0;
            alignment: center;

            // Header-Label
            SmallText {
                // codespell:ignore-next-line
                text: "MANUELLE AKTION ERFORDERLICH";
                highlight: true;
            }

            Rectangle {
                height: Layout.spacing-lg;
                background: transparent;
            }

            LargeText {
                text: command.text;
                primary: true;
            }

            Rectangle {
                height: Layout.spacing-xs;
                background: transparent;
            }

            Rectangle {
                height: 1px;
                background: Palette.border;
            }

            Rectangle {
                height: Layout.spacing-lg;
                background: transparent;
            }

            HorizontalLayout {
                alignment: center;
                spacing: Layout.spacing-sm;
                PulseDot { }

                SmallText {
                    // codespell:ignore-next-line
                    text: "MASCHINE PAUSIERT";
                }
            }

            Rectangle {
                height: Layout.spacing-lg;
                background: transparent;
            }

            Button {
                // codespell:ignore-next-line
                text: "ERLEDIGT — WEITER →";
                clicked => {
                    root.close();
                    root.confirmed();
                }
            }
        }
    }
}
