<?xml version="1.0" encoding="UTF-8"?>
<schema name="proto" displayName="Cocktail Maker Serial Protocol" endian="little" version="1"
    dslVersion="8">
    <description>
        Protocol used for serial communication between the cocktail-maker-app and the embedded
        controllers.
        Definition of the sender property:
        sender=client: embedded controller (cocktail-maker-embedded)
        sender=server: raspberry-pi (cocktail-maker-app)
    </description>


    <fields>
        <string name="Msg1Name" defaultValue="Message 1" />
        <string name="Msg2Name" defaultValue="Message 2" />
        <enum name="MsgId" type="uint8" semanticType="messageId">
            <validValue name="Msg1" val="0x1" displayName="^Msg1Name" />
            <validValue name="Msg2" val="0x2" displayName="^Msg2Name" />
        </enum>
    </fields>

    <interface name="FrameInterface">
        <int name="TransactionId" type="uint8" />
    </interface>

    <frame name="Frame">
        <sync name="Sync">
            <int name="SyncField" type="uint16" defaultValue="0xabcd" />
        </sync>
        <size name="Size">
            <int name="SizeField" type="uint16" />
        </size>
        <id name="Id" field="MsgId" />
        <value name="TransactionId">
            <interfaceFieldName value="TransactionId" />
            <field>
                <int name="TransactionIdField" type="uint8" />
            </field>
        </value>
        <payload name="Data" />
        <checksum name="Checksum" alg="crc-16" from="Size">
            <int name="ChecksumField" type="uint16" />
        </checksum>
    </frame>


    <message name="Msg2" id="MsgId.Msg2" displayName="^Msg2Name" sender="server">
        <description>
            Description
        </description>
        <fields>

        </fields>
    </message>


    <message name="Msg1" id="MsgId.Msg1" displayName="^Msg1Name" sender="client">
        <description>
            Description
        </description>
        <fields>

        </fields>
    </message>
</schema>